{
  "servers": {
    "github": {
      "type": "stdio",
      "stop": true,
      "command": "bash",
      "args": [
        "-lc",
        "echo 'intentional startup failure' >&2; exit 1"
      ]
    },
    "ollama-local-mcp": {
      "type": "stdio",
      "stop": true,
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "/home/daen/.config/github-copilot/mcps/ollama-local-mcp",
        "ollama-local-mcp"
      ]
    },
    "docker": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-docker-server"
      ],
      "env": {
        "DOCKER_HOST": "unix:///var/run/docker.sock"
      }
    },
    "markitdown": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "markitdown-mcp==0.0.1a4"
      ]
    },
