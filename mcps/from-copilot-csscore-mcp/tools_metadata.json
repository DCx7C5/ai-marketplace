        "required": true
      },
      "ttl": {
        "type": "number",
        "description": "Time-to-live in seconds",
        "required": false,
        "default": 3600
      }
    },
    "returns": {
      "type": "object",
      "description": "Store confirmation with cache metadata"
    }
