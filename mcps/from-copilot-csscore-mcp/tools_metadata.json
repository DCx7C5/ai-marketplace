        "required": false,
        "default": "default"
      }
    },
    "returns": {
      "type": "object",
      "description": "Cached value with metadata or error"
    },
    "keywords": [
      "memory",
      "storage",
      "fast-access"
    ]
  },
  {
    "id": "cache-store",
    "name": "Cache Store",
    "version": "1.0.0",
    "category": "cache-management",
    "mcp": "csscore-mcp",
    "status": "available",
    "description": "Store a value in the cache with optional TTL (time-to-live) expiration.",
    "tags": [
      "cache",
      "store",
      "storage"
    ],
    "parameters": {
      "key": {
        "type": "string",
        "description": "The cache key to store",
        "required": true
      },
      "value": {
        "type": "object",
