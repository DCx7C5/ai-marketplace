from contextlib import asynccontextmanager
from playwright.async_api import async_playwright
from playwright_stealth import stealth_async
from config import get_brave_path


@asynccontextmanager
async def browser_lifespan(app):
    async with async_playwright() as p:
        brave_path = get_brave_path()

        context = await p.chromium.launch_persistent_context(
            user_data_dir=app.state.user_data_dir,
            executable_path=brave_path,
            headless=True,
            args=[
                "--no-sandbox",
                "--disable-setuid-sandbox",
                "--disable-dev-shm-usage",
                "--disable-blink-features=AutomationControlled",
                "--disable-features=IsolateOrigins,site-per-process",
                "--mute-audio",
            ],
            viewport={"width": 1366, "height": 768},
            user_agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/134.0.0.0 Safari/537.36",
            locale="en-US",
            timezone_id="Europe/Berlin",
            java_script_enabled=True,
            permissions=[],
        )

        page = context.pages[0] if context.pages else await context.new_page()
        await stealth_async(page)

        # Fingerprint blocking script
        await context.add_init_script("""
            const origGetContext = HTMLCanvasElement.prototype.getContext;
            HTMLCanvasElement.prototype.getContext = function(type, ...args) {
                const ctx = origGetContext.call(this, type, ...args);
                if (ctx && (type === '2d' || type.includes('webgl'))) {
                    const origGetImageData = ctx.getImageData;
                    ctx.getImageData = function(x, y, w, h) {
                        const data = origGetImageData.call(this, x, y, w, h);
                        for (let i = 0; i < data.data.length; i += 4) {
                            data.data[i] ^= Math.floor(Math.random() * 3);
                        }
                        return data;
                    };
                }
                return ctx;
            };

            Object.defineProperty(navigator, 'hardwareConcurrency', { get: () => 8 });
            Object.defineProperty(navigator, 'deviceMemory', { get: () => 8 });
            Object.defineProperty(navigator, 'plugins', { get: () => [] });
        """)

        app.state.browser_context = context
        app.state.page = page

        print("✅ Brave Stealth MCP started")
        print(f"   Profile: {app.state.user_data_dir}")

        yield
        await context.close()
